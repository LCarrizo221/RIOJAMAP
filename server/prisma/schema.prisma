generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Obra {
  id             Int      @id @default(autoincrement())
  fecha          DateTime
  municipio      String
  referente      String
  concepto       String
  tipo           String
  estado         String
  montoTotal     Float
  montoParcial   Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
